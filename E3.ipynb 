    "import numpy as np\n",
    "from geopy.geocoders import Nominatim\n",
    "\n",
    "geolocator = Nominatim(user_agent='samos_assignment')\n",
    "\n",
    "places = [\n",
    "    'Walvis Bay Namibia',\n",
    "    'Cape Town South Africa',\n",
    "    'Rio de Janeiro Brazil',\n",
    "    'Montevideo Uruguay'\n",
    "]\n",
    "\n",
    "locations = [geolocator.geocode(p) for p in places]\n",
    "\n",
    "# Define extent: [lon_min, lon_max, lat_min, lat_max]\n",
    "extent = [-70, 20, -50, -20]\n",
    "\n",
    "central_lon = np.mean(extent[:2])\n",
    "central_lat = np.mean(extent[2:])\n",
    "\n",
    "plt.figure(figsize=(12,6))\n",
    "\n",
    "ax = plt.axes(projection=ccrs.AlbersEqualArea(\n",
    "    central_longitude=central_lon,\n",
    "    central_latitude=central_lat\n",
    "))\n",
    "\n",
    "ax.set_extent(extent, crs=ccrs.PlateCarree())\n",
    "\n",
    "# Features\n",
    "ax.add_feature(cfeature.LAND, facecolor='lightgray')\n",
    "ax.add_feature(cfeature.OCEAN, facecolor='lightblue')\n",
    "ax.coastlines()\n",
    "\n",
    "# Gridlines\n",
    "gl = ax.gridlines(draw_labels=True)\n",
    "gl.top_labels = False\n",
    "gl.right_labels = False\n",
    "\n",
    "# Plot locations\n",
    "for loc, name in zip(locations, places):\n",
    "    ax.plot(loc.longitude, loc.latitude,\n",
    "            marker='o', color='black',\n",
    "            transform=ccrs.Geodetic())\n",
    "    \n",
    "    ax.text(loc.longitude + 1,\n",
    "            loc.latitude,\n",
    "            name.split()[0],  # shorter label\n",
    "            transform=ccrs.Geodetic())\n",
    "\n",
    "plt.title('South Atlantic Ocean (20°S–50°S)')\n",
    "plt.show()"
   ]
