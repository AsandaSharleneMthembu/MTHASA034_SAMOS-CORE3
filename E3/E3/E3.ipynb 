    "## Exercise 2"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "be226a64-aa0a-42da-b8aa-0c1ccd6e454a",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1200x600 with 1 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "geolocator = Nominatim(user_agent='educational')\n",
    "\n",
    "extent = [-70, 20, -50, -20]\n",
    "\n",
    "central_lon = np.mean(extent[:2])\n",
    "central_lat = np.mean(extent[2:])\n",
    "\n",
    "place = ['Walvis Bay Namibia',\n",
    "         'Cape Town South Africa',\n",
    "         'Rio de Janeiro Brazil',\n",
    "         'Montevideo Uruguay']\n",
    "\n",
    "address = []\n",
    "for p in place:\n",
    "    loc = geolocator.geocode(p, language=\"en\")\n",
    "    address.append(loc)\n",
    "\n",
    "plt.figure(figsize=(12, 6))\n",
    "\n",
    "ax = plt.axes(projection=ccrs.PlateCarree())\n",
    "ax.set_extent(extent)\n",
    "\n",
    "# Features \n",
    "ax.add_feature(cfeature.OCEAN)\n",
    "ax.add_feature(cfeature.LAND, facecolor='lightgrey')\n",
    "ax.add_feature(cfeature.COASTLINE, linewidth=0.8)\n",
    "ax.add_feature(cfeature.BORDERS, linestyle=':', linewidth=0.5)\n",
    "\n",
    "# Gridlines \n",
    "gl = ax.gridlines(draw_labels=True, linestyle='--', alpha=0.4)\n",
    "gl.top_labels = False\n",
    "gl.right_labels = False\n",
    "gl.xlabel_style = {'size': 9}\n",
    "gl.ylabel_style = {'size': 9}\n",
    "\n",
    "# Plot locations\n",
    "for p in range(len(place)):\n",
    "    ax.plot(address[p].longitude,\n",
    "            address[p].latitude,\n",
    "            marker='o', color='red', markersize=5,\n",
    "            transform=ccrs.Geodetic())\n",
    "\n",
    "    ax.text(address[p].longitude + 1.2,\n",
    "            address[p].latitude - 0.5,\n",
    "            place[p].split()[0],\n",
    "            transform=ccrs.Geodetic(),\n",
    "            fontsize=9)\n",
    "\n",
    "# Title \n",
    "plt.title('South Atlantic Ocean (20°S–50°S)', fontsize=13, pad=10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
